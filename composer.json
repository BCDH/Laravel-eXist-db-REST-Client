{
    "name": "bcdh/exist-db-rest-client",
    "type": "library",
    "description": "A Laravel client for querying and transforming results from eXist-db via the REST API",
    "keywords": [
        "eXist-db",
        "xquery",
        "xslt",
        "php",
        "laravel",
        "rest"
    ],
    "homepage": "https://github.com/BCDH/Laravel-eXist-db-REST-Client",
    "license": "GPL-2.0-only",
    "require": {
        "php" : "^8.0.2",
        "illuminate/support": "^9.0",
        "guzzlehttp/guzzle": "^7.0",
        "sabre/xml": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit" : "^9.6",
        "scrutinizer/ocular": "~1.1",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "BCDH\\ExistDbRestClient\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BCDH\\ExistDbRestClient\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --verbose tests"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BCDH\\ExistDbRestClient\\ExistDbServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-1.x": "1.2.x-dev"
        }
    },
    "minimum-stability": "stable"
}
